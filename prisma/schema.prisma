generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CurriculumStatus {
  ACTIVE
  ARCHIVED
}

enum LessonDifficulty {
  FOUNDATION
  BEGINNER
  DEVELOPING
  PROFICIENT
  CHALLENGE
}

enum LessonPublicationStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
  ARCHIVED
}

enum LessonProgressStatus {
  LOCKED
  AVAILABLE
  IN_PROGRESS
  COMPLETED
  MASTERED
  REVISION_RECOMMENDED
}

enum LessonSessionStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ABANDONED
}

enum BlockAttemptStatus {
  UNANSWERED
  CORRECT
  PARTIALLY_CORRECT
  INCORRECT
  SKIPPED
}

enum MasteryStatus {
  NOT_STARTED
  EMERGING
  DEVELOPING
  PROFICIENT
  MASTERED
}

enum RewardSourceType {
  ANSWER
  LESSON_COMPLETION
  SCORE_IMPROVEMENT
  PERFECT_LESSON
  DAILY_GOAL
  STREAK
  BADGE
  ADMIN_ADJUSTMENT
  REVERSAL
}

enum BadgeCategory {
  LEARNING
  MASTERY
  IMPROVEMENT
  CONSISTENCY
  EXPLORATION
}

enum CurriculumImportStatus {
  UPLOADED
  EXTRACTING
  READY_FOR_REVIEW
  GENERATING
  DRAFT_READY
  FAILED
  PUBLISHED
}

enum CurriculumImportSubject {
  MATHEMATICS
  ENGLISH_LANGUAGE
  SCIENCE
}

model Subject {
  id          String           @id
  name        String
  slug        String           @unique
  description String
  icon        String
  colourToken String
  gradeLevels Int[]
  order       Int
  status      CurriculumStatus @default(ACTIVE)
  units       Unit[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([status, order])
}

model CurriculumImport {
  id                 String                  @id @default(cuid())
  subject            CurriculumImportSubject
  title              String
  sourceFileName     String
  sourceMimeType     String
  sourceSizeBytes    Int
  sourceChecksum     String
  status             CurriculumImportStatus @default(UPLOADED)
  requestedGrades    Int[]
  model              String
  promptVersion      String
  sourceText         String?
  generatedDraftJson Json?
  validationJson     Json?
  errorMessage       String?
  openaiResponseId   String?
  publishedSubjectId String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@index([subject, status])
  @@index([createdAt])
}

model Unit {
  id          String   @id
  subjectId   String
  name        String
  slug        String
  description String
  order       Int
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  topics      Topic[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([subjectId, slug])
  @@index([subjectId, order])
}

model Topic {
  id          String   @id
  unitId      String
  name        String
  slug        String
  description String
  order       Int
  unit        Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  lessons     Lesson[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([unitId, slug])
  @@index([unitId, order])
}

model Lesson {
  id                   String                  @id
  topicId              String
  title                String
  slug                 String
  shortDescription     String
  order                Int
  prerequisiteLessonId String?
  topic                Topic                   @relation(fields: [topicId], references: [id], onDelete: Cascade)
  prerequisiteLesson   Lesson?                 @relation("LessonPrerequisites", fields: [prerequisiteLessonId], references: [id])
  unlockedLessons      Lesson[]                @relation("LessonPrerequisites")
  versions             LessonVersion[]
  progress             StudentLessonProgress[]
  sessions             LessonSession[]
  attempts             LessonAttempt[]
  events               LearningEvent[]
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  @@unique([topicId, slug])
  @@index([topicId, order])
  @@index([prerequisiteLessonId])
}

model LessonVersion {
  id               String                  @id
  lessonId         String
  versionNumber    Int
  status           LessonPublicationStatus
  title            String
  description      String
  objectiveSummary String
  difficulty       LessonDifficulty
  estimatedMinutes Int
  baseXpReward     Int
  passingScore     Float
  masteryScore     Float
  maximumLessonRedos Int                    @default(2)
  publishedAt      DateTime?
  lesson           Lesson                  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  objectives       LearningObjective[]
  blocks           LessonBlock[]
  progress         StudentLessonProgress[]
  sessions         LessonSession[]
  attempts         LessonAttempt[]
  events           LearningEvent[]
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  @@unique([lessonId, versionNumber])
  @@index([lessonId, status])
}

model LearningObjective {
  id              String          @id
  lessonVersionId String
  code            String
  description     String
  order           Int
  lessonVersion   LessonVersion   @relation(fields: [lessonVersionId], references: [id], onDelete: Cascade)
  masteryRecords  MasteryRecord[]

  @@unique([lessonVersionId, code])
  @@index([lessonVersionId, order])
}

model LessonBlock {
  id               String        @id
  lessonVersionId  String
  type             String
  order            Int
  content          Json
  required         Boolean
  estimatedSeconds Int?
  lessonVersion    LessonVersion @relation(fields: [lessonVersionId], references: [id], onDelete: Cascade)
  blockAttempts    BlockAttempt[]
  events           LearningEvent[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([lessonVersionId, order])
  @@index([lessonVersionId, type])
}

model Student {
  id                String                  @id
  displayName       String
  age               Int
  totalXpCache      Int                     @default(0)
  currentLevelCache Int                     @default(1)
  dailyGoalXp       Int                     @default(60)
  currentStreakDays Int                     @default(0)
  progress          StudentLessonProgress[]
  sessions          LessonSession[]
  attempts          LessonAttempt[]
  masteryRecords    MasteryRecord[]
  events            LearningEvent[]
  rewards           RewardTransaction[]
  badgeAwards       BadgeAward[]
  streakRecord      StreakRecord?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
}

model StudentLessonProgress {
  id                        String               @id
  studentId                 String
  lessonId                  String
  activeLessonVersionId     String
  status                    LessonProgressStatus
  currentBlockId            String?
  completedRequiredBlocks   Int                  @default(0)
  totalRequiredBlocks       Int
  progressPercentage        Float                @default(0)
  latestScore               Float                @default(0)
  bestScore                 Float                @default(0)
  latestAccuracy            Float                @default(0)
  bestAccuracy              Float                @default(0)
  attemptCount              Int                  @default(0)
  stars                     Int                  @default(0)
  totalXpEarnedFromLesson   Int                  @default(0)
  firstStartedAt            DateTime?
  lastAccessedAt            DateTime?
  firstCompletedAt          DateTime?
  masteredAt                DateTime?
  revisionRecommendedAt     DateTime?
  student                   Student              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lesson                    Lesson               @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  activeLessonVersion       LessonVersion        @relation(fields: [activeLessonVersionId], references: [id])
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt

  @@unique([studentId, lessonId])
  @@index([studentId, status])
}

model LessonSession {
  id              String              @id
  studentId       String
  lessonId        String
  lessonVersionId String
  status          LessonSessionStatus
  startedAt       DateTime
  lastActivityAt  DateTime
  pausedAt        DateTime?
  completedAt     DateTime?
  currentBlockId  String?
  deviceSessionId String
  durationSeconds Int                 @default(0)
  student         Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lesson          Lesson              @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonVersion   LessonVersion       @relation(fields: [lessonVersionId], references: [id])
  attempts        LessonAttempt[]
  events          LearningEvent[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([studentId, status])
  @@index([studentId, lessonId, lessonVersionId])
}

model LessonAttempt {
  id                           String         @id
  studentId                    String
  lessonId                     String
  lessonVersionId              String
  lessonSessionId              String
  attemptNumber                Int
  scorePercentage              Float
  accuracyPercentage           Float
  totalAssessments             Int
  correctAssessments           Int
  partiallyCorrectAssessments  Int
  incorrectAssessments         Int
  xpAwarded                    Int
  starsAwarded                 Int
  passed                       Boolean
  mastered                     Boolean
  startedAt                    DateTime
  submittedAt                  DateTime
  durationSeconds              Int
  student                      Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lesson                       Lesson         @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonVersion                LessonVersion  @relation(fields: [lessonVersionId], references: [id])
  lessonSession                LessonSession  @relation(fields: [lessonSessionId], references: [id], onDelete: Cascade)
  blockAttempts                BlockAttempt[]

  @@unique([studentId, lessonVersionId, attemptNumber])
  @@index([lessonSessionId])
  @@index([studentId, lessonId])
}

model BlockAttempt {
  id                  String             @id
  lessonAttemptId     String
  blockId             String
  attemptNumber       Int
  status              BlockAttemptStatus
  scoreEarned         Float
  scorePossible       Float
  xpAwarded           Int
  hintUsed            Boolean
  responseTimeSeconds Int
  submittedAt         DateTime
  lessonAttempt       LessonAttempt      @relation(fields: [lessonAttemptId], references: [id], onDelete: Cascade)
  block               LessonBlock        @relation(fields: [blockId], references: [id])
  responses           StudentResponse[]

  @@index([lessonAttemptId])
  @@index([blockId])
}

model StudentResponse {
  id                     String       @id
  blockAttemptId         String
  responseJson           Json
  normalisedResponseJson Json
  isCorrect              Boolean
  feedbackShown          String
  createdAt              DateTime     @default(now())
  blockAttempt           BlockAttempt @relation(fields: [blockAttemptId], references: [id], onDelete: Cascade)

  @@index([blockAttemptId])
}

model MasteryRecord {
  id                  String            @id
  studentId           String
  learningObjectiveId String
  masteryStatus       MasteryStatus
  masteryScore        Float
  evidenceCount       Int               @default(0)
  lastEvidenceAt      DateTime?
  student             Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  learningObjective   LearningObjective @relation(fields: [learningObjectiveId], references: [id], onDelete: Cascade)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@unique([studentId, learningObjectiveId])
}

model LearningEvent {
  id              String        @id
  studentId       String
  sessionId       String
  lessonId        String
  lessonVersionId String
  blockId         String?
  verb            String
  objectType      String
  objectId        String
  resultJson      Json
  contextJson     Json
  occurredAt      DateTime
  recordedAt      DateTime      @default(now())
  eventVersion    Int           @default(1)
  idempotencyKey  String        @unique
  student         Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  session         LessonSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  lesson          Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  lessonVersion   LessonVersion @relation(fields: [lessonVersionId], references: [id])
  block           LessonBlock?  @relation(fields: [blockId], references: [id])

  @@index([studentId, occurredAt])
  @@index([lessonId, lessonVersionId])
  @@index([verb, objectType])
}

model RewardTransaction {
  id                    String           @id
  studentId             String
  sourceType            RewardSourceType
  sourceId              String
  ruleKey               String
  xpAmount              Int
  metadataJson          Json
  idempotencyKey        String           @unique
  awardedAt             DateTime
  reversedAt            DateTime?
  reversalTransactionId String?
  student               Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId, awardedAt])
  @@index([sourceType, sourceId])
}

model LevelDefinition {
  id        String   @id
  level     Int      @unique
  minimumXp Int
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BadgeDefinition {
  id           String        @id
  key          String        @unique
  name         String
  description  String
  iconKey      String
  category     BadgeCategory
  rarity       String
  criteriaType String
  criteriaJson Json
  active       Boolean       @default(true)
  awards       BadgeAward[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([active, category])
}

model BadgeAward {
  id           String          @id
  studentId    String
  badgeId      String
  sourceEventId String
  awardedAt    DateTime
  metadataJson Json
  student      Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  badge        BadgeDefinition @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([studentId, badgeId])
  @@index([badgeId])
}

model StreakRecord {
  id                  String   @id
  studentId           String   @unique
  currentStreakDays   Int      @default(0)
  longestStreakDays   Int      @default(0)
  lastQualifyingDate  String?
  timezone            String
  updatedAt           DateTime @updatedAt
  student             Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}
